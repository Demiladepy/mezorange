# Wallet used for deployments and transactions on Mezo Testnet
# NEVER commit real keys — copy to .env only (gitignored)
PRIVATE_KEY=your_private_key_here

# Mezo Testnet RPC (default: https://rpc.test.mezo.org)
TESTNET_RPC=https://rpc.test.mezo.org

# Goldsky subgraph URL belongs in frontend/.env.local as:
# Goldsky subgraph (frontend uses NEXT_PUBLIC_* in frontend/.env.local)
# PUBLIC_GRAPHQL_LINK=https://api.goldsky.com/api/public/project_cmp2yui5905ct01we90crcu19/subgraphs/mezorange-mezo-testnet/1.0.0/gn

# Optional: alias for pool-creation script (falls back to PRIVATE_KEY)
# DEPLOYER_PRIVATE_KEY=
# NPM_ADDRESS=
# SWAP_ROUTER_ADDRESS=
# POOL_ADDRESS=
# DEPLOY_DIRECT_VAULT=false
# TOKEN_A_ADDRESS=
# TOKEN_B_ADDRESS=
# RECIPIENT=
# AMOUNT=10000
