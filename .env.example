# Wallet used for deployments and transactions on Mezo Testnet
PRIVATE_KEY=your_private_key_here

# Mezo Testnet RPC (default: https://rpc.test.mezo.org)
TESTNET_RPC=https://rpc.test.mezo.org

# Optional deployment overrides (see scripts/deploy.ts)
# NPM_ADDRESS=
# SWAP_ROUTER_ADDRESS=
# POOL_ADDRESS=
# DEPLOY_DIRECT_VAULT=false
# TOKEN_A_ADDRESS=
# TOKEN_B_ADDRESS=
# RECIPIENT=
# AMOUNT=10000
