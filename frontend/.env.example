# WalletConnect Cloud project ID (required for RainbowKit / Passport)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# Mezo Testnet contract addresses (from deploy output)
NEXT_PUBLIC_VAULT_ADDRESS=
NEXT_PUBLIC_POOL_ADDRESS=
# Optional: factory if you deployed via MezrangeVaultFactory
NEXT_PUBLIC_FACTORY_ADDRESS=

# Goldsky hosted subgraph GraphQL endpoint (live vault indexer)
NEXT_PUBLIC_GOLDSKY_GRAPHQL_URL=https://api.goldsky.com/api/public/project_cmp2yui5905ct01we90crcu19/subgraphs/mezorange-mezo-testnet/1.0.0/gn

# Optional: override RPC (defaults to https://rpc.test.mezo.org via Passport)
NEXT_PUBLIC_MEZO_TESTNET_RPC=https://rpc.test.mezo.org
