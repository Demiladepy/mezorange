# Mezo Testnet RPC
TESTNET_RPC=https://rpc.test.mezo.org

# Keeper wallet private key (must match vault.keeper())
KEEPER_PRIVATE_KEY=

# Deployed MezrangeVault address
VAULT_ADDRESS=

# Uniswap V3 pool address (optional — read from vault.pool() if omitted)
POOL_ADDRESS=

# Poll slot0 on every new block in addition to Swap events
POLL_ON_BLOCK=true

# Minimum ms between rebalance checks for the same tick (debounce)
CHECK_DEBOUNCE_MS=3000

# Gas limit for rebalance() — used as floor; estimate * buffer is preferred
REBALANCE_GAS_LIMIT=1500000

# Extra gas headroom over estimateGas result (basis points, 2000 = 20%)
GAS_LIMIT_BUFFER_BPS=2000

# Optional max fee per gas in gwei (leave empty for network suggestion)
MAX_FEE_PER_GAS_GWEI=
MAX_PRIORITY_FEE_PER_GAS_GWEI=
